{
  "name": "nexus-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format --write .",
    "gen:proto": "cd ../nexus-proto/proto && buf build --path api/v1 --path shared/v1 -o ../../nexus-site/public/api-data/descriptor.json",
    "gen:api-data": "tsx scripts/gen-api-data.ts",
    "gen:context": "tsx scripts/gen-context.ts",
    "gen:llms": "tsx scripts/gen-llms-txt.ts",
    "gen": "pnpm gen:api-data && pnpm gen:context && pnpm gen:llms"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fumadocs-core": "^15.8.5",
    "fumadocs-mdx": "^13.0.8",
    "fumadocs-ui": "^15.8.5",
    "lucide-react": "^1.7.0",
    "next": "^15.3.2",
    "next-intl": "^4.9.0",
    "next-themes": "^0.4.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "shadcn": "^4.1.2",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@bufbuild/protobuf": "^2.11.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.2"
  }
}
